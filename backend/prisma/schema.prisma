generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                  @id @default(autoincrement())
  email            String               @unique
  passwordHash     String
  name             String
  phone            String?
  role             Role                 @default(CUSTOMER)
  status           UserStatus           @default(PENDING_KYC)
  
  // KYC Fields
  nationalId       String?              @unique
  selfieUrl        String?
  address          String?
  employmentStatus EmploymentStatus?
  kycStatus        KycStatus            @default(PENDING)
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  savingsAccount   SavingsAccount?
  financings       FinancingAgreement[]
  auditLogs        AuditLog[]           @relation("UserLogs")
  loanApplications LoanApplication[]
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation("UserLogs", fields: [userId], references: [id])
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Vehicle {
  id               Int                  @id @default(autoincrement())
  make             String
  model            String
  year             Int
  price            Decimal              @db.Decimal(12, 2)
  status           VehicleStatus        @default(AVAILABLE)
  dealerId         Int? // Can link to a Dealer user role in the future
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  financings       FinancingAgreement[]
  loanApplications LoanApplication[]
}

model SavingsAccount {
  id                        Int                  @id @default(autoincrement())
  userId                    Int                  @unique
  user                      User                 @relation(fields: [userId], references: [id])
  balance                   Decimal              @default(0.00) @db.Decimal(12, 2)
  targetAmount              Decimal              @db.Decimal(12, 2)
  interestEarned            Decimal              @default(0.00) @db.Decimal(12, 2)
  status                    AccountStatus        @default(ACTIVE)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  transactions              SavingsTransaction[]
}

model SavingsTransaction {
  id           Int               @id @default(autoincrement())
  accountId    Int
  account      SavingsAccount    @relation(fields: [accountId], references: [id])
  amount       Decimal           @db.Decimal(12, 2)
  type         SavingsTxType
  status       TransactionStatus @default(COMPLETED)
  reference    String?           @unique
  date         DateTime          @default(now())
}

model LoanApplication {
  id              Int                 @id @default(autoincrement())
  userId          Int
  user            User                @relation(fields: [userId], references: [id])
  vehicleId       Int
  vehicle         Vehicle             @relation(fields: [vehicleId], references: [id])
  requestedAmount Decimal             @db.Decimal(12, 2)
  status          LoanAppStatus       @default(PENDING)
  riskScore       Int?                // 0 - 100
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model FinancingAgreement {
  id                   Int               @id @default(autoincrement())
  customerId           Int
  user                 User              @relation(fields: [customerId], references: [id])
  vehicleId            Int
  vehicle              Vehicle           @relation(fields: [vehicleId], references: [id])
  principalAmount      Decimal           @db.Decimal(12, 2)
  monthlyInstallment   Decimal           @db.Decimal(12, 2)
  interestRate         Decimal           @db.Decimal(5, 2)
  startDate            DateTime          @default(now())
  endDate              DateTime
  status               FinancingStatus   @default(ACTIVE)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  repayments           Repayment[]
}

model Repayment {
  id              Int                 @id @default(autoincrement())
  agreementId     Int
  agreement       FinancingAgreement  @relation(fields: [agreementId], references: [id])
  amount          Decimal             @db.Decimal(12, 2)
  status          RepaymentStatus     @default(PENDING)
  dueDate         DateTime
  paidDate        DateTime?
  createdAt       DateTime            @default(now())
}

// ENUMS

enum Role {
  CUSTOMER
  ADMIN
  LOAN_OFFICER
  RECOVERY_OFFICER
  DEALER
  SUPER_ADMIN
}

enum UserStatus {
  PENDING_KYC
  ACTIVE
  SUSPENDED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED
  STUDENT
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  FINANCED
  SOLD
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum SavingsTxType {
  DEPOSIT
  WITHDRAWAL
  BONUS
  INTEREST
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum LoanAppStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum FinancingStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum RepaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}
